# --- Client (safe to ship in the browser bundle) ---------------------------
# Dynamic environment ID — get one from https://app.dynamic.xyz
VITE_DYNAMIC_ENVIRONMENT_ID=

# --- Server-only (NEVER shipped to the browser) ----------------------------
# Used only by the gateway proxy. For `vite dev`, put these in .env.local (the
# dev middleware reads them Node-side). For `wrangler pages dev` and production
# Cloudflare Pages, set them as Pages env vars / .dev.vars instead.
# These are intentionally NOT VITE_-prefixed, so Vite never injects them into
# import.meta.env or the client bundle. The gateway secret must stay here.
GATEWAY_URL=https://gateway.africoin.ai
DEX_APP_ID=dex
DEX_APP_KEY_ID=dex-v1
DEX_GATEWAY_SECRET=
DEX_PUBLIC_ORIGIN=https://swap.africoin.ai
