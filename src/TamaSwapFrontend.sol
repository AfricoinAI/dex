function walletName(w,i){let p=w.provider,n=w.info?.name;if(n)return n;if(p?.isMetaMask)return "MetaMask";if(p?.isCoinbaseWallet)return "Coinbase Wallet";if(p?.isRabby)return "Rabby";return "Wallet "+(i+1)}
function addWallet(p,i={}){if(!p||WALLETS.some(w=>w.provider===p))return;WALLETS.push({provider:p,info:i});p.on?.("chainChanged",()=>location.reload());p.on?.("accountsChanged",()=>location.reload());renderWallets()}
function renderWallets(){wallets.textContent="";WALLETS.forEach((w,i)=>{let b=document.createElement("button");b.className="item";let l=document.createElement("span");l.className="logo";if(w.info?.icon){let im=document.createElement("img");im.src=w.info.icon;l.append(im)}else l.textContent=walletName(w,i).slice(0,2);let d=document.createElement("div"),s=document.createElement("div"),a=document.createElement("div");s.className="sym";s.textContent=walletName(w,i);a.className="addr";a.textContent=w.info?.rdns||"Injected wallet";d.append(s,a);b.append(l,d);b.onclick=()=>connectWallet(w.provider).catch(e=>status(e.message,true));wallets.append(b)});walletStat.textContent=WALLETS.length?`${WALLETS.length} wallet${WALLETS.length===1?"":"s"} detected`:"No wallet detected"}
function detectWallets(){window.addEventListener("eip6963:announceProvider",e=>addWallet(e.detail?.provider,e.detail?.info||{}));window.dispatchEvent(new Event("eip6963:requestProvider"));let eth=window.ethereum;if(eth?.providers)eth.providers.forEach((p,i)=>addWallet(p,{name:p.name||walletName({provider:p},i)}));else if(eth)addWallet(eth,{name:"Browser wallet"});setTimeout(renderWallets,100)}
async function connectWallet(p){if(p)E=p;if(!E){if(WALLETS.length===1)return connectWallet(WALLETS[0].provider);throw Error("No wallet detected")}let a=await rpc("eth_requestAccounts",[]);AC=a[0];CID=Number(await rpc("eth_chainId",[]));connect.textContent=sh(AC);connect.className="wallet ok";chain.textContent="Chain "+CID;walletModal.classList.remove("on");await loadLists();updateAll()}
function openWallets(){if(WALLETS.length===1)connectWallet(WALLETS[0].provider).catch(e=>status(e.message,true));else{renderWallets();walletModal.classList.add("on")}}
connect.onclick=openWallets;closeWallet.onclick=()=>walletModal.classList.remove("on");walletModal.onclick=e=>{if(e.target===walletModal)walletModal.classList.remove("on")};
detectWallets();setTimeout(()=>{if(WALLETS[0]){E=WALLETS[0].provider;rpc("eth_accounts",[]).then(async a=>{CID=Number(await rpc("eth_chainId",[]));if(a[0]){AC=a[0];connect.textContent=sh(AC);connect.className="wallet ok";chain.textContent="Chain "+CID}await loadLists()}).catch(()=>loadLists())}else loadLists()},150);
async function loadLists(){listStat.textContent="Loading token list...";let urls=JSON.parse(localStorage.tamaLists||"null")||[DEFAULT_LIST];let all=[];for(let u of urls){try{let j=await (await fetch(u)).json();if(!Array.isArray(j.tokens))throw Error("bad list");all.push(...j.tokens.filter(t=>t.chainId===CID&&isA(t.address)).map(t=>({address:low(t.address),symbol:t.symbol||"???",name:t.name||t.symbol||"Token",decimals:t.decimals??18,logoURI:t.logoURI||""})))}catch(e){listStat.textContent="Token list unavailable. Paste a token address to import manually."}}let m=new Map();all.forEach(t=>m.set(t.address,t));TOK=[...m.values()].sort((a,b)=>a.symbol.localeCompare(b.symbol));MAP=m;listStat.textContent=TOK.length?`${TOK.length} tokens loaded for chain ${CID}`:"No listed tokens for this chain. Paste an address.";renderTokens()}
loadList.onclick=async()=>{let u=listUrl.value.trim();if(!u)return;let urls=JSON.parse(localStorage.tamaLists||"null")||[DEFAULT_LIST];if(!urls.includes(u))urls.unshift(u);localStorage.tamaLists=JSON.stringify(urls.slice(0,5));await loadLists()};
function openPick(k){activePick=k;modal.classList.add("on");search.value="";renderTokens();search.focus()}
closeModal.onclick=()=>modal.classList.remove("on");modal.onclick=e=>{if(e.target===modal)modal.classList.remove("on")};search.oninput=renderTokens;
["pickIn","pickOut","pickLpA","pickLpB","pickBurnA","pickBurnB","pickPoolA","pickPoolB"].forEach(id=>$(id).onclick=()=>openPick(id));
async function tokenMeta(a){let t=MAP.get(low(a));if(t)return t;need();let d=18,sym="TOKEN",name="Token";try{d=Number(BigInt(await raw(a,"0x313ce567")))}catch(e){}try{sym=decStr(await raw(a,"0x95d89b41"))||sym}catch(e){}try{name=decStr(await raw(a,"0x06fdde03"))||name}catch(e){}t={address:low(a),symbol:sym,name,decimals:d,logoURI:""};MAP.set(t.address,t);TOK.unshift(t);return t}
function decStr(h){h=h.slice(2);if(h.length===64)return hexToText(h);let o=Number(BigInt("0x"+h.slice(0,64)))*2,l=Number(BigInt("0x"+h.slice(o,o+64)))*2;return hexToText(h.slice(o+64,o+64+l))}
function hexToText(h){let s="";for(let i=0;i<h.length;i+=2){let c=parseInt(h.slice(i,i+2),16);if(c)s+=String.fromCharCode(c)}return s.trim()}
function renderTokens(){tokens.textContent="";let q=low(search.value.trim()),arr=TOK.filter(t=>!q||low(t.symbol).includes(q)||low(t.name).includes(q)||low(t.address).includes(q)).slice(0,80);if(isA(q)&&!MAP.has(q))arr=[{address:q,symbol:"Import",name:"Import token by address",decimals:18},...arr];for(let t of arr){let b=document.createElement("button");b.className="item";let l=document.createElement("span");l.className="logo";l.textContent=t.symbol.slice(0,2);let d=document.createElement("div"),s=document.createElement("div"),a=document.createElement("div");s.className="sym";s.textContent=t.symbol;a.className="addr";a.textContent=t.name+" - "+sh(t.address);d.append(s,a);b.append(l,d);b.onclick=async()=>{let x=await tokenMeta(t.address);setSel(activePick,x);modal.classList.remove("on")};tokens.append(b)}}
async function price(t){if(!t)return null;let slug=SLUG[CID];if(!slug)return null;let k=slug+":"+t.address,c=PX.get(k);if(c&&Date.now()-c.ts<60000)return c.p;try{let j=await (await fetch("https://coins.llama.fi/prices/current/"+k)).json(),p=j?.coins?.[k]?.price;if(typeof p==="number"&&p>0){PX.set(k,{p,ts:Date.now()});return p}}catch(e){}PX.set(k,{p:null,ts:Date.now()});return null}
async function updateUsd(inp,t,out){let p=await price(t),v=parseFloat(inp.value||"0");out.textContent=p&&v?money(v*p):"";priceState.textContent=p?"DeFiLlama pricing":"Price unavailable"}
function pairFor(a,b){return raw(FACTORY,cd("0xe6a43905",ea(a)+ea(b))).then(r=>"0x"+r.slice(26))}
async function reserves(a,b){let p=await pairFor(a,b);if(BigInt(p)===0n)return [p,0n,0n];let r=await raw(p,"0x0902f1ac"),x=BigInt("0x"+r.slice(2,66)),y=BigInt("0x"+r.slice(66,130)),t0=low("0x"+(await raw(p,"0x0dfe1681")).slice(26));return [p,...(low(a)===t0?[x,y]:[y,x])]}
async function quote(){let a=selected("pickIn"),b=selected("pickOut"),amt=parseAmt(swapAmt.value,a?.decimals||18);if(!a||!b||amt===0n){swapOutAmt.value="";return}let data=cd("0xd06ca61f",p32(amt)+p32(64)+p32(2)+ea(a.address)+ea(b.address));try{let r=await raw(ROUTER,data),out=BigInt("0x"+r.slice(194,258));swapOutAmt.value=fmtAmt(out,b.decimals);minOut.textContent=fmtAmt(out*995n/1000n,b.decimals)+" "+b.symbol}catch(e){swapOutAmt.value="";minOut.textContent="-";status("No route or insufficient liquidity",true)}updateUsd(swapAmt,a,usdIn);updateUsd(swapOutAmt,b,usdOut)}
function updateAll(){quote().catch(()=>{});updateUsd(lpAmtA,selected("pickLpA"),lpUsdA);updateUsd(lpAmtB,selected("pickLpB"),lpUsdB);checkPair().catch(()=>{})}
swapAmt.oninput=updateAll;lpAmtA.oninput=updateAll;lpAmtB.oninput=updateAll;refresh.onclick=updateAll;flip.onclick=()=>{let a=selected("pickIn"),b=selected("pickOut");setSel("pickIn",b);setSel("pickOut",a)};
tabSwap.onclick=()=>{tabSwap.className="on";tabPool.className="";swapView.classList.remove("hide");poolView.classList.add("hide")};tabPool.onclick=()=>{tabPool.className="on";tabSwap.className="";poolView.classList.remove("hide");swapView.classList.add("hide")};
document.querySelectorAll("[data-pool]").forEach(b=>b.onclick=()=>{document.querySelectorAll("[data-pool]").forEach(x=>x.classList.remove("on"));b.classList.add("on");["addPool","removePool","createPool"].forEach(x=>$(x).classList.add("hide"));$({add:"addPool",remove:"removePool",create:"createPool"}[b.dataset.pool]).classList.remove("hide")});
function approveData(spender,amt){return cd("0x095ea7b3",ea(spender)+p32(amt))}
async function approveToken(t,amt){need();if(!t)throw Error("Select token first");return await tx(t.address,approveData(ROUTER,amt||2n**256n-1n))}
approveSwap.onclick=async()=>{try{status(await approveToken(selected("pickIn")))}catch(e){status(e.message,true)}};
approveLp.onclick=async()=>{try{let a=selected("pickLpA"),b=selected("pickLpB");status(await approveToken(a),false,true);status(await approveToken(b),false,true)}catch(e){status(e.message,true,true)}};
approvePair.onclick=async()=>{try{need();await checkPair();if(!PAIR||BigInt(PAIR)===0n)throw Error("No pair found");status(await tx(PAIR,approveData(ROUTER,2n**256n-1n)),false,true)}catch(e){status(e.message,true,true)}};
doSwap.onclick=async()=>{try{need();await quote();let a=selected("pickIn"),b=selected("pickOut"),ain=parseAmt(swapAmt.value,a.decimals),min=parseAmt(swapOutAmt.value,b.decimals)*995n/1000n,d=cd("0x38ed1739",p32(ain)+p32(min)+p32(160)+ea(AC)+p32(dl())+p32(2)+ea(a.address)+ea(b.address));status(await tx(ROUTER,d))}catch(e){status(e.message,true)}};
doLp.onclick=async()=>{try{need();let a=selected("pickLpA"),b=selected("pickLpB"),aa=parseAmt(lpAmtA.value,a.decimals),bb=parseAmt(lpAmtB.value,b.decimals),d=cd("0xe8e33700",ea(a.address)+ea(b.address)+p32(aa)+p32(bb)+p32(0)+p32(0)+ea(AC)+p32(dl()));status(await tx(ROUTER,d),false,true)}catch(e){status(e.message,true,true)}};
function pairTokens(){return removePool.classList.contains("hide")?[selected("pickPoolA"),selected("pickPoolB")]:[selected("pickBurnA"),selected("pickBurnB")]}
async function checkPair(){let [a,b]=pairTokens();if(!a||!b)return;let p=await pairFor(a.address,b.address);PAIR=p;pairOut.textContent=BigInt(p)===0n?"No pool":sh(p);pairInfo.textContent=BigInt(p)===0n?"No pair found":sh(p)}
findPool.onclick=()=>checkPair().catch(e=>status(e.message,true,true));
makePool.onclick=async()=>{try{need();let a=selected("pickPoolA"),b=selected("pickPoolB");status(await tx(FACTORY,cd("0xc9c65396",ea(a.address)+ea(b.address))),false,true);await checkPair()}catch(e){status(e.message,true,true)}};
doBurn.onclick=async()=>{try{need();let a=selected("pickBurnA"),b=selected("pickBurnB");await checkPair();let liq=parseAmt(burnLiq.value,18),d=cd("0xbaa2abde",ea(a.address)+ea(b.address)+p32(liq)+p32(0)+p32(0)+ea(AC)+p32(dl()));status(await tx(ROUTER,d),false,true)}catch(e){status(e.message,true,true)}};
</script>

