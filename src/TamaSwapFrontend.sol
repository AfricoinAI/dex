      <div class=row><label>Token<input id=apTok placeholder="0x..."></label><label>Amount<input id=apAmt placeholder="max"></label></div>
      <div class=actions><button id=approveRouter>Approve router</button><button class=secondary id=approvePair>Approve pair LP</button></div>
      <div class=status>Approvals are separate transactions. For removing liquidity, approve the LP pair token.</div>
    </section>
  </main>
</div>
<script>
const FACTORY="__FACTORY__",ROUTER="__ROUTER__";
const A="0x0000000000000000000000000000000000000000";
let E=null,AC=null;
const $=id=>document.getElementById(id),sp=x=>(x||"").trim(),hex=x=>x.startsWith("0x")?x:"0x"+x;
const isA=x=>/^0x[0-9a-fA-F]{40}$/.test(x),sh=x=>x&&isA(x)?x.slice(0,6)+"..."+x.slice(-4):"-";
const p32=v=>BigInt(v).toString(16).padStart(64,"0");
const ea=a=>sp(a).toLowerCase().slice(2).padStart(64,"0");
const sel=s=>s,dl=()=>Math.floor(Date.now()/1000)+1200;
const dec=s=>{s=sp(s);if(!s)return 0n;let [i,f=""]=s.split(".");f=(f+"0".repeat(18)).slice(0,18);return BigInt(i||0)*10n**18n+BigInt(f)};
const fmt=n=>{n=BigInt(n||0);let s=n.toString().padStart(19,"0"),i=s.slice(0,-18),f=s.slice(-18).replace(/0+$/,"");return f?i+"."+f.slice(0,6):i};
const rpc=(m,p)=>E.request({method:m,params:p});
factoryAddr.textContent=FACTORY;routerAddr.textContent=ROUTER;
function cd(sig,args=""){return sig+args}
async function call(to,data){return await rpc("eth_call",[{to,data},"latest"])}
async function tx(to,data){return await rpc("eth_sendTransaction",[{from:AC,to,data}])}
function setStat(x,bad=false){stat.textContent=x;stat.className=bad?"status err":"status"}
async function connect(){
 if(!window.ethereum){setStat("No wallet detected.",true);return}
 E=window.ethereum;const a=await rpc("eth_requestAccounts",[]);AC=a[0];acct.textContent=sh(AC);connect.textContent="Connected";
 const c=await rpc("eth_chainId",[]);net.textContent="chain "+BigInt(c).toString();setStat("");
}
function need(){if(!AC)throw Error("Connect wallet first")}
function approveData(spender,amount){return cd("0x095ea7b3",ea(spender)+p32(amount))}
async function ensurePair(a,b){
 if(!isA(a)||!isA(b))throw Error("Bad token address");
 const r=await call(FACTORY,cd("0xe6a43905",ea(a)+ea(b)));
 return "0x"+r.slice(26);
}
async function getRes(a,b){
 const p=await ensurePair(a,b);if(BigInt(p)===0n)return [p,0n,0n];
 const r=await call(p,"0x0902f1ac");
 const x=BigInt("0x"+r.slice(2,66)),y=BigInt("0x"+r.slice(66,130));
 const t0=await call(p,"0x0dfe1681");
 const token0=("0x"+t0.slice(26)).toLowerCase();
 return [p,...(a.toLowerCase()===token0?[x,y]:[y,x])];
}
async function quoteSwap(){
 const path=[sp(swapIn.value),sp(swapOut.value)],amt=dec(swapAmt.value);
 if(!isA(path[0])||!isA(path[1])||amt===0n)throw Error("Enter tokens and amount");
 const data=cd("0xd06ca61f",p32(amt)+p32(64)+p32(2)+ea(path[0])+ea(path[1]));
 const r=await call(ROUTER,data),out=BigInt("0x"+r.slice(194,258));
 swapMin.value=fmt(out*995n/1000n);setStat("Quote: "+fmt(out)+" out");
}
async function find(){
 const a=sp(poolA.value),b=sp(poolB.value);const [p,ra,rb]=await getRes(a,b);
 pairOut.textContent=BigInt(p)===0n?"not created":p;reserves.textContent=BigInt(p)===0n?"-":fmt(ra)+" / "+fmt(rb);
}
tabs=document.querySelectorAll(".tab");tabs.forEach(t=>t.onclick=()=>{tabs.forEach(x=>x.classList.remove("on"));t.classList.add("on");["swap","lp","burn"].forEach(id=>$(id).classList.toggle("hide",id!==t.dataset.tab));setStat("")});
connect.onclick=()=>connect().catch(e=>setStat(e.message||e,true));
qSwap.onclick=()=>quoteSwap().catch(e=>setStat(e.message||e,true));
doSwap.onclick=async()=>{try{need();if(!swapMin.value)await quoteSwap();const a=dec(swapAmt.value),m=dec(swapMin.value),x=sp(swapIn.value),y=sp(swapOut.value);const d=cd("0x38ed1739",p32(a)+p32(m)+p32(160)+ea(AC)+p32(dl())+p32(2)+ea(x)+ea(y));setStat(await tx(ROUTER,d))}catch(e){setStat(e.message||e,true)}};
doLp.onclick=async()=>{try{need();const d=cd("0xe8e33700",ea(lpA.value)+ea(lpB.value)+p32(dec(lpAmtA.value))+p32(dec(lpAmtB.value))+p32(dec(lpMinA.value))+p32(dec(lpMinB.value))+ea(AC)+p32(dl()));setStat(await tx(ROUTER,d))}catch(e){setStat(e.message||e,true)}};
doBurn.onclick=async()=>{try{need();const d=cd("0xbaa2abde",ea(burnA.value)+ea(burnB.value)+p32(dec(burnLiq.value))+p32(dec(burnMinA.value))+p32(dec(burnMinB.value))+ea(AC)+p32(dl()));setStat(await tx(ROUTER,d))}catch(e){setStat(e.message||e,true)}};
findPool.onclick=()=>find().catch(e=>setStat(e.message||e,true));
createPool.onclick=async()=>{try{need();const d=cd("0xc9c65396",ea(poolA.value)+ea(poolB.value));setStat(await tx(FACTORY,d))}catch(e){setStat(e.message||e,true)}};
approveRouter.onclick=async()=>{try{need();const amt=sp(apAmt.value).toLowerCase()==="max"||!sp(apAmt.value)?(2n**256n-1n):dec(apAmt.value);setStat(await tx(sp(apTok.value),approveData(ROUTER,amt)))}catch(e){setStat(e.message||e,true)}};
approvePair.onclick=async()=>{try{need();const p=pairOut.textContent;if(!isA(p))throw Error("Find pair first");const amt=sp(apAmt.value).toLowerCase()==="max"||!sp(apAmt.value)?(2n**256n-1n):dec(apAmt.value);setStat(await tx(p,approveData(ROUTER,amt)))}catch(e){setStat(e.message||e,true)}};
if(window.ethereum)connect().catch(()=>{});
</script>

