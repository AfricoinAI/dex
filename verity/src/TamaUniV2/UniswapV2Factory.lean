def pairInitializeModule : ExternalCallModule where
  name := "uniswapV2PairInitialize"
  numArgs := 3
  resultVars := []
  writesState := true
  readsState := false
  axioms := ["pair_initialize_interface"]
  proofStatus := .assumed
  compile := fun _ctx args => do
    let [pairExpr, token0Expr, token1Expr] := args
      | throw "uniswapV2PairInitialize expects 3 arguments (pair, token0, token1)"
    let selectorWord := 0x485cc95500000000000000000000000000000000000000000000000000000000
    pure [YulStmt.block [
      YulStmt.expr (YulExpr.call "mstore" [YulExpr.lit 0, YulExpr.hex selectorWord]),
      YulStmt.expr (YulExpr.call "mstore" [YulExpr.lit 4, token0Expr]),
      YulStmt.expr (YulExpr.call "mstore" [YulExpr.lit 36, token1Expr]),
      YulStmt.let_ "__uv2_init_success" (YulExpr.call "call" [
        YulExpr.call "gas" [], pairExpr, YulExpr.lit 0,
        YulExpr.lit 0, YulExpr.lit 68, YulExpr.lit 0, YulExpr.lit 0
      ]),
      YulStmt.if_ (YulExpr.call "iszero" [YulExpr.ident "__uv2_init_success"]) [
        YulStmt.let_ "__uv2_init_rds" (YulExpr.call "returndatasize" []),
        YulStmt.expr (YulExpr.call "returndatacopy" [YulExpr.lit 0, YulExpr.lit 0, YulExpr.ident "__uv2_init_rds"]),
        YulStmt.expr (YulExpr.call "revert" [YulExpr.lit 0, YulExpr.ident "__uv2_init_rds"])
      ],
      YulStmt.expr (YulExpr.call "mstore" [YulExpr.lit 64, YulExpr.lit 128])
    ]]

def pairCreate2Module (resultVar : String) : ExternalCallModule where
  name := "uniswapV2PairCreate2"
  numArgs := 2
  resultVars := [resultVar]
  writesState := true
  readsState := true
  axioms := ["pair_create2_interface"]
  proofStatus := .assumed
  compile := fun _ctx args => do
    let [token0Expr, token1Expr] := args
      | throw "uniswapV2PairCreate2 expects 2 arguments (token0, token1)"
    let saltSetup := [
      YulStmt.expr (YulExpr.call "mstore" [
        YulExpr.lit 0,
        YulExpr.call "shl" [YulExpr.lit 96, token0Expr]
      ]),
      YulStmt.expr (YulExpr.call "mstore" [
        YulExpr.lit 20,
        YulExpr.call "shl" [YulExpr.lit 96, token1Expr]
      ]),
      YulStmt.let_ "__uv2_pair_salt" (YulExpr.call "keccak256" [YulExpr.lit 0, YulExpr.lit 40])
    ]
    let codeStores := pairCreationCodeChunks.zipIdx.map fun (chunk, idx) =>
      YulStmt.expr (YulExpr.call "mstore" [YulExpr.lit (idx * 32), YulExpr.hex chunk])
    pure (saltSetup ++ codeStores ++ [
      YulStmt.let_ resultVar (YulExpr.call "create2" [
        YulExpr.lit 0,
        YulExpr.lit 0,
        YulExpr.lit pairCreationCodeLength,
        YulExpr.ident "__uv2_pair_salt"
      ])
    ])

verity_contract UniswapV2FactoryBase where
  storage
    pairForSlot : Address → Address → Uint256 := slot 0
    allPairsSlot : Uint256 → Uint256 := slot 1
    allPairsLengthSlot : Uint256 := slot 2

  function view getPair (tokenA : Address, tokenB : Address) : Address := do
    let pairWord ← getMapping2 pairForSlot tokenA tokenB
    return (wordToAddress pairWord)

  function view allPairs (index : Uint256) : Address := do
    let length ← getStorage allPairsLengthSlot
    require (index < length) "UniswapV2: INDEX_OUT_OF_BOUNDS"
    let pairWord ← getMappingUint allPairsSlot index
    return (wordToAddress pairWord)

  function view allPairsLength () : Uint256 := do
    let length ← getStorage allPairsLengthSlot
    return length

  function allow_post_interaction_writes createPair (tokenA : Address, tokenB : Address) : Address := do
    require (tokenA != tokenB) "UniswapV2: IDENTICAL_ADDRESSES"
    require (tokenA != zeroAddress && tokenB != zeroAddress) "UniswapV2: ZERO_ADDRESS"
    let tokenASortsFirst := (addressToWord tokenA) < (addressToWord tokenB)
    let mut token0Value := tokenA
    let mut token1Value := tokenB
    if tokenASortsFirst then
      pure ()
    else
      token0Value := tokenB
      token1Value := tokenA
    let existing ← getMapping2 pairForSlot token0Value token1Value
    require (existing == 0) "UniswapV2: PAIR_EXISTS"
    let pairWord ← ecmCall (fun resultVar => pairCreate2Module resultVar) [token0Value, token1Value]
    let pair := wordToAddress pairWord
    require (pair != zeroAddress) "UniswapV2: CREATE2_FAILED"
    ecmDo pairInitializeModule [pair, token0Value, token1Value]
    setMapping2 pairForSlot token0Value token1Value pairWord
    setMapping2 pairForSlot token1Value token0Value pairWord
    let lengthBefore ← getStorage allPairsLengthSlot
    let lengthAfter ← requireSomeUint (safeAdd lengthBefore 1) "UniswapV2: PAIR_COUNT_OVERFLOW"
    setMappingUint allPairsSlot lengthBefore pairWord
    setStorage allPairsLengthSlot lengthAfter
    emit "PairCreated" [addressToWord token0Value, addressToWord token1Value, addressToWord pair, lengthAfter]
    return pair

namespace UniswapV2Factory

abbrev pairForSlot := UniswapV2FactoryBase.pairForSlot
abbrev allPairsSlot := UniswapV2FactoryBase.allPairsSlot
abbrev allPairsLengthSlot := UniswapV2FactoryBase.allPairsLengthSlot

abbrev getPair := UniswapV2FactoryBase.getPair
abbrev allPairs := UniswapV2FactoryBase.allPairs
abbrev allPairsLength := UniswapV2FactoryBase.allPairsLength
abbrev createPair := UniswapV2FactoryBase.createPair

def spec : CompilationModel :=
  { UniswapV2FactoryBase.spec with
    name := "UniswapV2Factory"
    events := [
      UniswapV2FactoryEvents.pairCreated
    ] }

end UniswapV2Factory

end TamaUniV2
